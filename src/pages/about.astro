---
import { render } from "astro:content";
import AboutGrid from "@/components/about/AboutGrid.astro";
import AboutLinkItem from "@/components/about/AboutLinkItem.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { I18n } from "@/i18n/utils";
import { getLocalizedSingletonEntry } from "@/utils/content";
import { sharedMdxComponents } from "@/utils/mdx";

const entry = await getLocalizedSingletonEntry("about", I18n.defaultLocale);
const { Content } = await render(entry);
---

<BaseLayout
  lang={I18n.defaultLocale}
  title={entry.data.title}
  description={entry.data.description}
>
  <div class="bg-[#1678d3] text-white py-16 mb-8">
    <h1
      class="my-16 font-semibold text-5xl md:text-6xl text-center container max-w-8xl mx-auto"
    >
      jyutping.org
    </h1>
  </div>

  <div class="container mx-auto px-4 py-4 text-gray-800">
    <Content components={{ ...sharedMdxComponents, AboutGrid, AboutLinkItem }} />
  </div>
</BaseLayout>
