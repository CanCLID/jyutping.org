---
import type { CollectionEntry } from "astro:content";
import { render } from "astro:content";
import TableOfContents from "@/components/TableOfContents";
import ContentWithTocShell from "@/components/content/ContentWithTocShell.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import {
  getEntryLocale,
  getNonDefaultLocaleCollectionEntryStaticPaths,
  isSupportedLocale,
} from "@/utils/content";
import { sharedMdxComponents } from "@/utils/mdx";

export async function getStaticPaths() {
  return getNonDefaultLocaleCollectionEntryStaticPaths("learn");
}

interface Props {
  entry: CollectionEntry<"learn">;
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);
const { locale } = Astro.params;

if (!locale || !isSupportedLocale(locale)) {
  throw new Error(`Invalid locale parameter for learn page: ${locale ?? "undefined"}.`);
}

const lang = getEntryLocale(entry.id) || locale;
---

<BaseLayout
  title={entry.data.title}
  description={entry.data.description}
  lang={lang}
>
  <ContentWithTocShell
    title={entry.data.title}
    description={entry.data.description}
  >
    <Content components={sharedMdxComponents} />
    <TableOfContents slot="toc" client:load headings={headings} />
  </ContentWithTocShell>
</BaseLayout>
