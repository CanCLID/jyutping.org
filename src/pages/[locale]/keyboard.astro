---
import BaseLayout from "@/layouts/BaseLayout.astro";
import KeyboardPage from "@/components/KeyboardPage.astro";
import { getNonDefaultLocaleStaticPaths } from "@/i18n/utils";
import { getTitle } from "@/i18n/pageHeadings";

export function getStaticPaths() {
  return getNonDefaultLocaleStaticPaths();
}

const { locale } = Astro.params;

const title = getTitle("keyboard", locale);
---

<BaseLayout lang={locale} title={title}>
  <KeyboardPage locale={locale} />
</BaseLayout>
