---
import { render } from "astro:content";
import AboutGrid from "@/components/about/AboutGrid.astro";
import AboutLinkItem from "@/components/about/AboutLinkItem.astro";
import InlineLink from "@/components/InlineLink.astro";
import Paragraph from "@/components/Paragraph.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getNonDefaultLocaleStaticPaths } from "@/i18n/utils";
import { getLocalizedSingletonEntry, isSupportedLocale } from "@/utils/content";

export function getStaticPaths() {
  return getNonDefaultLocaleStaticPaths();
}

const { locale } = Astro.params;

if (!locale || !isSupportedLocale(locale)) {
  throw new Error(`Invalid locale parameter for about page: ${locale ?? "undefined"}.`);
}

const entry = await getLocalizedSingletonEntry("about", locale);
const { Content } = await render(entry);
---

<BaseLayout
  lang={locale}
  title={entry.data.title}
  description={entry.data.description}
>
  <div class="bg-[#1678d3] text-white py-16 mb-8">
    <h1
      class="my-16 font-semibold text-5xl md:text-6xl text-center container max-w-8xl mx-auto"
    >
      jyutping.org
    </h1>
  </div>
  <div class="container mx-auto px-4 py-4 text-gray-800">
    <Content components={{ AboutGrid, AboutLinkItem, InlineLink, Paragraph }} />
  </div>
</BaseLayout>
