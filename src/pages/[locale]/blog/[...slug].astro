---
import type { CollectionEntry } from "astro:content";
import { render } from "astro:content";
import BlogCatalogue from "@/components/BlogCatalogue.astro";
import TableOfContents from "@/components/TableOfContents";
import CatalogueContentShell from "@/components/content/CatalogueContentShell.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import {
  getEntryLocale,
  getEntrySlug,
  getLocalizedCollectionEntries,
  getNonDefaultLocaleCollectionEntryStaticPaths,
  isSupportedLocale,
} from "@/utils/content";
import { sharedMdxComponents } from "@/utils/mdx";

export async function getStaticPaths() {
  return getNonDefaultLocaleCollectionEntryStaticPaths("blog");
}

interface Props {
  entry: CollectionEntry<"blog">;
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);
const { locale } = Astro.params;

if (!locale || !isSupportedLocale(locale)) {
  throw new Error(`Invalid locale parameter for blog page: ${locale ?? "undefined"}.`);
}

const allBlogEntries = await getLocalizedCollectionEntries("blog", locale);
allBlogEntries.sort((a, b) => (a.data.weight || 0) - (b.data.weight || 0));

const lang = getEntryLocale(entry.id) || locale;
---

<BaseLayout
  title={entry.data.title}
  description={entry.data.description}
  lang={lang}
>
  <CatalogueContentShell
    title={entry.data.title}
    description={entry.data.description}
  >
    <BlogCatalogue
      slot="catalogue"
      posts={allBlogEntries}
      currentSlug={getEntrySlug(entry.id)}
    />
    <Content components={sharedMdxComponents} />
    <TableOfContents slot="toc" client:load headings={headings} />
  </CatalogueContentShell>
</BaseLayout>
