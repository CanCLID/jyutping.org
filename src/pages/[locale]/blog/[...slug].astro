---
import type { CollectionEntry } from "astro:content";
import { getCollection, render } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import TableOfContents from "@/components/TableOfContents";
import BlogCatalogue from "@/components/BlogCatalogue.astro";
import { I18n } from "@/i18n/utils";
import {
  getEntryLocale,
  getEntrySlug,
  isLocaleEntry,
  isSupportedLocale,
} from "@/utils/content";

// 1. Generate paths for all non-default locale blog posts
export async function getStaticPaths() {
  const blogEntries = await getCollection("blog", ({ id }) => {
    // Filter for entries NOT in the default locale
    return !isLocaleEntry(id, I18n.defaultLocale);
  });

  return blogEntries
    .map((entry) => {
      const locale = getEntryLocale(entry.id);
      if (!isSupportedLocale(locale)) {
        console.warn(
          `Invalid locale "${locale}" found in blog entry id: ${entry.id}. Skipping.`
        );
        return null;
      }

      const slug = getEntrySlug(entry.id);

      return {
        params: { locale, slug: slug || undefined },
        props: { entry },
      };
    })
    .filter((path) => path !== null);
}

// 2. Get the entry for the current page
interface Props {
  entry: CollectionEntry<"blog">;
}
const { entry } = Astro.props;
const { Content, headings } = await render(entry);

// Fetch all blog posts for the current locale
const locale = Astro.params.locale;
const allBlogEntries = await getCollection("blog", ({ id }) =>
  getEntryLocale(id) === locale
);

allBlogEntries.sort((a, b) => (a.data.weight || 0) - (b.data.weight || 0));

// Determine language for the layout
const lang = getEntryLocale(entry.id) || I18n.defaultLocale;
---

<BaseLayout
  title={entry.data.title}
  description={entry.data.description}
  lang={lang}
>
  <div class="flex justify-center mx-auto max-w-6xl">
    {/* Header */}
    <aside class="hidden w-48 lg:block flex-shrink-0 float-end">
      <div class="sticky top-32">
        <BlogCatalogue
          posts={allBlogEntries}
          currentSlug={getEntrySlug(entry.id)}
        />
      </div>
    </aside>

    <div class="flex justify-center gap-4 px-4 py-8 mx-auto">
      {/* Main content area */}
      <article class="prose flex-grow">
        <h1>{entry.data.title}</h1>
        {entry.data.description && <p class="lead">{entry.data.description}</p>}
        <hr class="my-4" />
        <Content />
      </article>

      <aside class="hidden lg:block w-64 flex-shrink-0">
        <div class="sticky top-32">
          <TableOfContents client:load headings={headings} />
        </div>
      </aside>
    </div>
  </div>
</BaseLayout>
