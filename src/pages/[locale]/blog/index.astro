---
import BaseLayout from "@/layouts/BaseLayout.astro";
import BlogIndexList from "@/components/BlogIndexList.astro";
import { getNonDefaultLocaleStaticPaths } from "@/i18n/utils";
import { getTitle } from "@/i18n/pageHeadings";
import { getBlogLabels } from "@/i18n/blogLabels";
import {
  getLocalizedCollectionEntries,
  getLocalizedContentPath,
  isSupportedLocale,
} from "@/utils/content";

export function getStaticPaths() {
  return getNonDefaultLocaleStaticPaths();
}

const { locale } = Astro.params;

if (!locale || !isSupportedLocale(locale)) {
  throw new Error(`Invalid locale parameter for blog index page: ${locale ?? "undefined"}.`);
}

const postsData = await getLocalizedCollectionEntries("blog", locale);

const posts = postsData.map((post) => ({
  title: post.data.title,
  slug: getLocalizedContentPath("blog", post.id),
  description: post.data.description,
}));

const title = getTitle("blog", locale);
const blogLabels = getBlogLabels(locale);
---

<BaseLayout lang={locale} title={title}>
  <BlogIndexList posts={posts} translations={{ title, ...blogLabels }} />
</BaseLayout>
