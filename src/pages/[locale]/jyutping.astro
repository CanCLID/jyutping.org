---
import { render } from "astro:content";
import TableOfContents from "@/components/TableOfContents";
import CodaTable from "@/components/jyutping/CodaTable.astro";
import FinalsChart from "@/components/jyutping/FinalsChart.astro";
import NucleiTable from "@/components/jyutping/NucleiTable.astro";
import OnsetTable from "@/components/jyutping/OnsetTable.astro";
import ReferenceList from "@/components/jyutping/ReferenceList.astro";
import SectionHeading from "@/components/jyutping/SectionHeading.astro";
import SubsectionHeading from "@/components/jyutping/SubsectionHeading.astro";
import SyllabicNasalTable from "@/components/jyutping/SyllabicNasalTable.astro";
import ToneTable from "@/components/jyutping/ToneTable.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getJyutpingSections } from "@/data/jyutping";
import { getNonDefaultLocaleStaticPaths } from "@/i18n/utils";
import { getLocalizedSingletonEntry, isSupportedLocale } from "@/utils/content";
import { sharedMdxComponents } from "@/utils/mdx";

export function getStaticPaths() {
  return getNonDefaultLocaleStaticPaths();
}

const { locale } = Astro.params;

if (!locale || !isSupportedLocale(locale)) {
  throw new Error(`Invalid locale parameter for jyutping page: ${locale ?? "undefined"}.`);
}

const entry = await getLocalizedSingletonEntry("jyutping", locale);
const { Content } = await render(entry);
const headings = getJyutpingSections(locale);
---

<BaseLayout
  lang={locale}
  title={entry.data.title}
  description={entry.data.description}
>
  <div class="bg-[#1678d3] text-white px-4 py-6 mb-8">
    <h1
      class="font-jyutping my-4 text-5xl md:text-6xl leading-relaxed text-center container max-w-8xl mx-auto"
    >
      粵拼：香港語言學學會粵語拼音方案
    </h1>
    <h1
      class="chiron-font my-8 text-3xl md:text-4xl text-center container max-w-8xl mx-auto"
    >
      Jyutping: The Linguistic Society of Hong Kong <br /> Cantonese Romanization
      Scheme
    </h1>
  </div>
  <div class="flex justify-center gap-8 max-w-5xl mx-auto">
    <article class="container max-w-4xl mx-auto p-4">
      <Content
        components={{
          ...sharedMdxComponents,
          CodaTable,
          FinalsChart,
          NucleiTable,
          OnsetTable,
          ReferenceList,
          SectionHeading,
          SubsectionHeading,
          SyllabicNasalTable,
          ToneTable,
        }}
      />
    </article>
    <aside class="hidden lg:block w-32 flex-shrink-0">
      <div class="sticky top-32">
        <TableOfContents client:load headings={headings} />
      </div>
    </aside>
  </div>
</BaseLayout>
