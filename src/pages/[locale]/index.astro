---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getNonDefaultLocaleStaticPaths } from "@/i18n/utils";
import { getTitle } from "@/i18n/pageHeadings";

import IndexPage from "@/components/IndexPage.astro";

export function getStaticPaths() {
  return getNonDefaultLocaleStaticPaths();
}

const { locale } = Astro.params;

const title = getTitle("index", locale);
---

<BaseLayout lang={locale} title={title} flipTitle>
  <IndexPage locale={locale} />
</BaseLayout>
