---
import { getJyutpingSection, type JyutpingSectionKey } from "@/data/jyutping";

interface Props {
  locale: string;
  section: JyutpingSectionKey;
}

const { locale, section } = Astro.props;
const heading = getJyutpingSection(locale, section);

if (heading.depth !== 2) {
  throw new Error(`SectionHeading received non-h2 Jyutping section: ${section}`);
}
---

<h2 id={heading.id} class="mt-8 mb-4 scroll-mt-20 text-3xl font-semibold">
  {heading.text}
</h2>
