---
import { I18n } from "@/i18n/utils";
import type { CollectionEntry } from "astro:content";
import { getTitle } from "@/i18n/pageHeadings";
import { getEntrySlug } from "@/utils/content";

// Get current locale from Astro's global
const { currentLocale } = Astro;
const locale = currentLocale || I18n.defaultLocale;

const title = getTitle("blog", locale);

interface Props {
  posts: CollectionEntry<"blog">[];
  currentSlug: string;
}

const { posts, currentSlug } = Astro.props;

// Posts are pre-sorted by weight in the parent page
---

<nav aria-label="Blog Catalogue">
  <h2 class="text-2xl px-4 font-bold mb-4">{title}</h2>
  <ul class="space-y-2 px-4">
    {
      posts.map((post) => {
        const postSlug = getEntrySlug(post.id);
        const localePrefix = locale === I18n.defaultLocale ? "" : `/${locale}`;
        const postLink = `${localePrefix}/blog/${postSlug}/`;
        const isActive =
          postSlug === currentSlug &&
          (localePrefix === "" || localePrefix === `/${locale}`);
        return (
          <li>
            <a
              href={postLink}
              class:list={[
                "block text-lg hover:text-blue-500",
                { "font-bold": isActive },
              ]}
              aria-current={isActive ? "page" : false}
            >
              {post.data.title}
            </a>
          </li>
        );
      })
    }
  </ul>
</nav>
